# =============================================================================
# Poly VST3 Plugin - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Build Directories
# -----------------------------------------------------------------------------
build/
Build/
out/
cmake-build-*/
**/build/
**/Build/
**/out/
build-test/
build-*/

# -----------------------------------------------------------------------------
# External SDKs (downloaded during CI)
# -----------------------------------------------------------------------------
vst3sdk/

# -----------------------------------------------------------------------------
# CMake
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt
!**/cmake/jk_*.cmake
compile_commands.json
_deps/

# -----------------------------------------------------------------------------
# Xcode
# -----------------------------------------------------------------------------
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.mode1v3
*.mode2v3
*.perspectivev3
*.pbxuser
DerivedData/
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.xcuserstate

# -----------------------------------------------------------------------------
# Visual Studio
# -----------------------------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.ncb
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb
ipch/
*.aps
*.tlog
*.lastbuildstate
*.ilk

# -----------------------------------------------------------------------------
# VST3 Binaries and Bundles
# -----------------------------------------------------------------------------
*.vst3
*.dSYM/
*.vst3/

# -----------------------------------------------------------------------------
# Compiled Object Files
# -----------------------------------------------------------------------------
*.o
*.obj
*.lo
*.slo
*.ko
*.elf
*.gch
*.pch

# -----------------------------------------------------------------------------
# Libraries
# -----------------------------------------------------------------------------
*.lib
*.a
*.la
*.lai

# -----------------------------------------------------------------------------
# Shared Objects / Dynamic Libraries
# -----------------------------------------------------------------------------
*.so
*.so.*
*.dylib
*.dll

# -----------------------------------------------------------------------------
# Executables
# -----------------------------------------------------------------------------
*.exe
*.out
*.app

# -----------------------------------------------------------------------------
# Debug Symbols
# -----------------------------------------------------------------------------
*.pdb
*.dSYM/
*.su
*.idb

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# IDE - VS Code
# Keep useful configs, ignore user-specific settings
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/c_cpp_properties.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# IDE - JetBrains (CLion)
# -----------------------------------------------------------------------------
.idea/
*.iml

# -----------------------------------------------------------------------------
# Coverage Reports
# -----------------------------------------------------------------------------
coverage/
coverage-report/
*.gcov
*.gcda
*.gcno
coverage.info
lcov.info
*.profraw
*.profdata

# -----------------------------------------------------------------------------
# Test Outputs
# -----------------------------------------------------------------------------
test-results/
Testing/
CTestTestfile.cmake
tests/ui/visual/references/

# -----------------------------------------------------------------------------
# Documentation Generation
# -----------------------------------------------------------------------------
docs/_build/
docs/html/
docs/latex/
doxygen/

# -----------------------------------------------------------------------------
# Package Managers
# -----------------------------------------------------------------------------
vcpkg_installed/
conan/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Archives
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.rar
*.7z

# -----------------------------------------------------------------------------
# NFR Review Artifacts
# -----------------------------------------------------------------------------
graphify-out/
poly-nfr-review.*

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------
.claude/settings.local.json

# -----------------------------------------------------------------------------
# Reports (NFR review output, machine-generated)
# -----------------------------------------------------------------------------
reports/

# -----------------------------------------------------------------------------
# Site Build Output
# -----------------------------------------------------------------------------
site/dist/

# -----------------------------------------------------------------------------
# GSD (project management artifacts — not published)
# -----------------------------------------------------------------------------
.gsd/

# -----------------------------------------------------------------------------
# Internal Docs (planning, UAT, reviews — not published)
# -----------------------------------------------------------------------------
internal-docs/
docs/internal/

# -----------------------------------------------------------------------------
# Web UI
# -----------------------------------------------------------------------------
webui/node_modules/
webui/test-results/
webui/playwright-report/
