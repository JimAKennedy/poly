---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const src = `${base}webui/index.html?preset=Afrobeat%2012%2F8`;
---

<figure class="ui-overview">
  <div class="ui-overview-container">
    <iframe
      class="ui-overview-frame"
      src={src}
      title="Poly — Afrobeat 12/8 preset with section labels"
      loading="lazy"
      sandbox="allow-scripts allow-same-origin"
      allow="autoplay"
    ></iframe>
    <span class="ui-label" style="top: 1.5%">1</span>
    <span class="ui-label" style="top: 14%">2</span>
    <span class="ui-label" style="top: 35%">3</span>
    <span class="ui-label" style="top: 51%">4</span>
    <span class="ui-label" style="top: 60.5%">5</span>
    <span class="ui-label" style="top: 73%">6</span>
    <span class="ui-label" style="top: 91%">7</span>
  </div>
  <figcaption>
    Poly interface (Afrobeat 12/8 preset) &mdash;
    <b>1</b>&thinsp;Header &middot;
    <b>2</b>&thinsp;Lane Grid &middot;
    <b>3</b>&thinsp;Lane Editor &middot;
    <b>4</b>&thinsp;Macros &middot;
    <b>5</b>&thinsp;Velocity &middot;
    <b>6</b>&thinsp;Visualization &middot;
    <b>7</b>&thinsp;Cross-Rhythm
  </figcaption>
</figure>

<style>
  .ui-overview {
    margin: 1.5rem 0;
  }

  .ui-overview-container {
    position: relative;
    border: 2px solid var(--poly-primary);
    border-radius: 8px;
    overflow: hidden;
    background: #1c1b19;
  }

  .ui-overview-frame {
    display: block;
    width: 100%;
    height: 520px;
    border: none;
    background: transparent;
  }

  .ui-label {
    position: absolute;
    left: 0.4rem;
    width: 1.3rem;
    height: 1.3rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--sl-color-accent, #01696f);
    color: #fff;
    font-family: var(--poly-font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
    pointer-events: none;
    z-index: 2;
  }

  figcaption {
    font-family: var(--poly-font-sans);
    font-size: var(--sl-text-xs);
    color: var(--poly-text-muted);
    margin-top: 0.4rem;
    text-align: center;
    line-height: 1.5;
  }

  figcaption b {
    color: var(--sl-color-accent, #01696f);
  }
</style>
