---
import Default from '@astrojs/starlight/components/Footer.astro';

const creditsHref = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/credits/`;
---

<Default><slot /></Default>

<div class="poly-attrib">
	<p>
		Preview audio uses CC0 and CC-BY drum samples. Every sample is credited on the
		<a href={creditsHref}>Credits &amp; Licenses</a> page.
	</p>
</div>

<style>
	.poly-attrib {
		margin-top: 2rem;
		padding-top: 1rem;
		border-top: 1px solid var(--sl-color-gray-5);
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		text-align: center;
	}
	.poly-attrib p {
		margin: 0;
	}
	.poly-attrib a {
		color: var(--sl-color-gray-2);
	}
	.poly-attrib a:hover {
		color: var(--sl-color-white);
	}
</style>
