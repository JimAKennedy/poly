---
import manifest from '../../public/samples/manifest.json';

type Sample = {
  file: string;
  spdx: string;
  attribution?: string;
  source: string;
  sourceUrl?: string;
  midiNotes: number[];
  role?: string;
  tags?: string[];
};

const samples = manifest.samples as Sample[];

const ccBy = samples
  .filter((s) => s.spdx !== 'CC0-1.0')
  .slice()
  .sort((a, b) => a.file.localeCompare(b.file));

const cc0 = samples.filter((s) => s.spdx === 'CC0-1.0');

const cc0Sources = new Map<string, { url: string; count: number }>();
for (const s of cc0) {
  const existing = cc0Sources.get(s.source);
  if (existing) {
    existing.count += 1;
  } else {
    cc0Sources.set(s.source, { url: s.sourceUrl ?? '', count: 1 });
  }
}
const cc0SourceList = Array.from(cc0Sources.entries())
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([name, info]) => ({ name, url: info.url, count: info.count }));

const licenseUrls: Record<string, string> = {
  'CC-BY-4.0': 'https://creativecommons.org/licenses/by/4.0/',
  'CC-BY-3.0': 'https://creativecommons.org/licenses/by/3.0/',
  'Artistic-2.0': 'https://www.perlfoundation.org/artistic-license-20.html',
  MIT: 'https://spdx.org/licenses/MIT.html',
};
---

<section class="credits">
  <h2>Attributed sources (CC-BY)</h2>
  <p class="credits-intro">
    Each row below carries the TASL string (Title / Author / Source / License)
    required by the Creative Commons Attribution license. If you redistribute
    or remix these samples, keep the attribution intact.
  </p>
  <table class="credits-table">
    <thead>
      <tr>
        <th>Source</th>
        <th>Attribution</th>
        <th>License</th>
        <th>File</th>
      </tr>
    </thead>
    <tbody>
      {
        ccBy.map((entry) => (
          <tr>
            <td>
              {entry.sourceUrl ? (
                <a href={entry.sourceUrl}>{entry.source}</a>
              ) : (
                entry.source
              )}
            </td>
            <td class="attribution">{entry.attribution}</td>
            <td>
              <a href={licenseUrls[entry.spdx] ?? '#'}>{entry.spdx}</a>
            </td>
            <td>
              <code>{entry.file}</code>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>Public-domain sources (CC0-1.0)</h2>
  <p class="credits-intro">
    No attribution required, but gratefully acknowledged. These libraries
    provided most of the drum vocabulary that ships with Poly.
  </p>
  <ul class="cc0-list">
    {
      cc0SourceList.map((s) => (
        <li>
          {s.url ? <a href={s.url}>{s.name}</a> : s.name}
          <span class="cc0-count"> — {s.count} sample{s.count === 1 ? '' : 's'}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .credits-intro {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
    margin-bottom: 0.75rem;
  }
  .credits-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 2rem;
    font-size: var(--sl-text-sm);
  }
  .credits-table th,
  .credits-table td {
    text-align: left;
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    vertical-align: top;
  }
  .credits-table th {
    border-bottom-width: 2px;
    font-weight: 600;
    white-space: nowrap;
  }
  .credits-table .attribution {
    font-size: 0.85em;
    line-height: 1.4;
  }
  .credits-table code {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.85em;
    white-space: nowrap;
  }
  .cc0-list {
    padding-left: 1.2rem;
    margin: 0;
  }
  .cc0-list li {
    margin: 0.25rem 0;
  }
  .cc0-count {
    color: var(--sl-color-gray-3);
    font-size: 0.9em;
  }
</style>
