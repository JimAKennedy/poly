---
import { Code } from 'astro:components';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  file: string;
  region: string;
  caption?: string;
}

const { file, region, caption } = Astro.props;

const projectRoot = path.resolve(process.cwd(), '..');
const filePath = path.join(projectRoot, file);

const EXT_TO_LANG: Record<string, string> = {
  '.cpp': 'cpp',
  '.cc': 'cpp',
  '.h': 'cpp',
  '.hpp': 'cpp',
  '.ts': 'ts',
  '.tsx': 'tsx',
  '.mjs': 'js',
  '.js': 'js',
  '.sh': 'bash',
  '.bash': 'bash',
  '.yaml': 'yaml',
  '.yml': 'yaml',
  '.json': 'json',
  '.astro': 'astro',
  '.mdx': 'mdx',
  '.md': 'md',
  '.css': 'css',
  '.html': 'html',
};

const ext = path.extname(file).toLowerCase();
const lang = EXT_TO_LANG[ext] ?? 'plaintext';

let content: string;
try {
  content = fs.readFileSync(filePath, 'utf-8');
} catch (err) {
  throw new Error(
    `CodeSnippet: could not read source file "${file}" (region "${region}"): ${(err as Error).message}`,
  );
}

const lines = content.split('\n');

const REGION_PATTERNS = [`// region:${region}`, `# region:${region}`];
const ENDREGION_PATTERNS = [`// endregion:${region}`, `# endregion:${region}`];

const startIdx = lines.findIndex((l) => REGION_PATTERNS.includes(l.trim()));
const endIdx = lines.findIndex((l) => ENDREGION_PATTERNS.includes(l.trim()));

if (startIdx === -1) {
  throw new Error(
    `CodeSnippet: region "${region}" start marker not found in "${file}" (expected "// region:${region}" or "# region:${region}")`,
  );
}
if (endIdx === -1) {
  throw new Error(
    `CodeSnippet: region "${region}" end marker not found in "${file}" (expected "// endregion:${region}" or "# endregion:${region}")`,
  );
}
if (endIdx <= startIdx) {
  throw new Error(
    `CodeSnippet: region "${region}" end marker precedes start marker in "${file}"`,
  );
}

const rawLines = lines.slice(startIdx + 1, endIdx);
const nonEmpty = rawLines.filter((l) => l.trim().length > 0);
const minIndent = nonEmpty.reduce((min, l) => {
  const indent = l.match(/^(\s*)/)?.[1].length ?? 0;
  return Math.min(min, indent);
}, Infinity);
const code = rawLines
  .map((l) => l.slice(minIndent === Infinity ? 0 : minIndent))
  .join('\n')
  .trimEnd();

const githubUrl = `https://github.com/JimAKennedy/poly/blob/main/${file}`;
---

<div class="code-snippet">
  <div class="code-snippet-header">
    <a href={githubUrl} class="code-snippet-file" target="_blank" rel="noopener">{file}</a>
  </div>
  <div class="code-snippet-body">
    <Code code={code} lang={lang as any} />
  </div>
  {caption && <div class="code-snippet-caption">{caption}</div>}
</div>

<style>
  .code-snippet {
    background: var(--poly-code-bg);
    border-radius: 6px;
    margin: 1.5rem 0;
    overflow: hidden;
  }

  .code-snippet-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.75rem;
    background: rgba(255, 255, 255, 0.08);
    font-family: var(--sl-font-system-mono);
    font-size: 0.75rem;
  }

  .code-snippet-file {
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }

  .code-snippet-file:hover {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: underline;
  }

  .code-snippet-body {
    padding: 0;
  }

  .code-snippet-body :global(pre) {
    margin: 0;
    border-radius: 0;
    padding: 1rem 0.75rem;
  }

  .code-snippet-caption {
    padding: 0.3rem 0.75rem 0.5rem;
    font-family: var(--poly-font-sans);
    font-size: var(--sl-text-xs);
    color: rgba(255, 255, 255, 0.45);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
</style>
