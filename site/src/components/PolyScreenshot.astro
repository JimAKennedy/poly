---
interface Props {
  src: string;
  caption?: string;
}

const { src, caption } = Astro.props;
---

<figure class="poly-screenshot">
  <div class="poly-screenshot-frame">
    <img
      src={src}
      alt={caption || 'Poly UI screenshot'}
      loading="lazy"
      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />
    <div class="poly-screenshot-placeholder">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="8.5" cy="8.5" r="1.5" />
        <path d="M21 15l-5-5L5 21" />
      </svg>
      <span>Screenshot pending</span>
    </div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .poly-screenshot {
    margin: 1.5rem 0;
  }

  .poly-screenshot-frame {
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 6px;
    overflow: hidden;
    background: var(--poly-surface);
  }

  .poly-screenshot-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .poly-screenshot-placeholder {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 3rem 1rem;
    color: var(--sl-color-gray-2);
    font-family: var(--poly-font-sans);
    font-size: var(--sl-text-sm);
  }

  figcaption {
    font-family: var(--poly-font-sans);
    font-size: var(--sl-text-xs);
    color: var(--poly-text-muted);
    margin-top: 0.4rem;
    text-align: center;
  }
</style>
