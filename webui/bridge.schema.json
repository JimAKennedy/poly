{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "poly-bridge-v1",
  "description": "Poly Web UI ↔ Native bridge wire format (v1). See bridge-schema.md. The applyPreset action's index refers to the runtime preset inventory (see site/src/generated/presets.json, emitted from engine/src/presets.cpp) — do NOT hard-code a maximum here; the count is defined by that inventory.",

  "definitions": {
    "envelope": {
      "type": "object",
      "properties": {
        "target": { "type": "string", "enum": ["Velocity", "Density", "Probability", "AccentBias", "NoteLength", "TimingLooseness", "ActivationWeight", "FillLikelihood"] },
        "period": { "type": "number", "minimum": 0 },
        "depth":  { "type": "number" },
        "on":     { "type": "boolean" },
        "shape":  { "type": "integer" },
        "curvature":   { "type": "number" },
        "phaseOffset": { "type": "number" }
      },
      "required": ["target", "period", "depth", "on"]
    },

    "lane": {
      "type": "object",
      "properties": {
        "name":     { "type": "string" },
        "hue":      { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "role":     { "type": "string", "enum": ["Anchor pulse", "Backbeat", "Shimmer", "Accent", "Ghost", "Ornament", "Fill", "Custom"] },
        "note":     { "type": "integer", "minimum": 0, "maximum": 127 },
        "ch":       { "type": "integer", "minimum": 0, "maximum": 16 },
        "steps":    { "type": "integer", "minimum": 1, "maximum": 64 },
        "subdivision": { "type": "integer", "enum": [1, 2, 4, 8, 16] },
        "stepLen":  { "type": "number", "exclusiveMinimum": 0 },
        "vel":      { "type": "integer", "minimum": 0, "maximum": 127 },
        "prob":     { "type": "number", "minimum": 0, "maximum": 1 },
        "spread":   { "type": "number", "minimum": 0 },
        "ghost":    { "type": "integer", "minimum": 0, "maximum": 127 },
        "push":     { "type": "number" },
        "hits":     { "type": "integer", "minimum": 0 },
        "rot":      { "type": "integer", "minimum": 0 },
        "timeline": { "type": "boolean" },
        "active":   { "type": "boolean" },
        "pattern":  { "type": "array", "items": { "type": "integer", "enum": [0, 1] } },
        "fixed":    { "oneOf": [{ "type": "null" }, { "type": "array", "items": { "type": "integer", "enum": [0, 1] } }] },
        "cells":    { "oneOf": [{ "type": "null" }, { "type": "array", "items": { "type": "integer", "minimum": 1 } }] },
        "cellCount": { "type": "integer", "minimum": 0 },
        "mt":       { "type": "array", "items": { "type": "number" } },
        "envs":     { "type": "array", "items": { "$ref": "#/definitions/envelope" } },
        "accents":  { "type": "array", "items": { "type": "number" } },
        "humanize":       { "type": "number" },
        "swing":          { "type": "number" },
        "duration":       { "type": "number" },
        "emphasisProb":   { "type": "number" },
        "timingOffset":   { "type": "number" },
        "mutationRate":   { "type": "number" },
        "driftRate":      { "type": "number" },
        "phraseLength":   { "type": "number" },
        "phraseGap":      { "type": "number" },
        "phraseOffset":   { "type": "number" },
        "tempoMultiplier": { "type": "number" },
        "kotekanSource":  { "type": "integer" }
      },
      "required": ["name", "role", "note", "ch", "steps", "vel", "prob", "hits", "rot", "pattern", "mt", "envs"]
    },

    "presetInfo": {
      "type": "object",
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      },
      "required": ["name", "description"]
    },

    "chainEntry": {
      "type": "object",
      "properties": {
        "scene": { "type": "integer" },
        "bars":  { "type": "integer", "minimum": 1 }
      },
      "required": ["scene", "bars"]
    },

    "chain": {
      "type": "object",
      "properties": {
        "enabled":    { "type": "boolean" },
        "mode":       { "type": "integer" },
        "entryCount": { "type": "integer", "minimum": 0 },
        "entries":    { "type": "array", "items": { "$ref": "#/definitions/chainEntry" } }
      },
      "required": ["enabled", "mode", "entryCount", "entries"]
    },

    "macros": {
      "type": "object",
      "properties": {
        "complexity":  { "type": "number", "minimum": 0, "maximum": 1 },
        "density":     { "type": "number", "minimum": 0, "maximum": 1 },
        "syncopation": { "type": "number", "minimum": 0, "maximum": 1 },
        "swing":       { "type": "number", "minimum": 0, "maximum": 1 },
        "tension":     { "type": "number", "minimum": 0, "maximum": 1 },
        "humanize":    { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["complexity", "density", "syncopation", "swing", "tension", "humanize"]
    },

    "state": {
      "type": "object",
      "properties": {
        "preset":  { "type": "string" },
        "seed":    { "type": "integer", "minimum": 0 },
        "tempo":   { "type": "number", "minimum": 0 },
        "scene":   { "type": "string", "enum": ["A", "B", "Morph"] },
        "morph":   { "type": "number" },
        "macros":  { "$ref": "#/definitions/macros" },
        "lanes":   { "type": "array", "items": { "$ref": "#/definitions/lane" }, "minItems": 1, "maxItems": 8 },
        "presets": { "type": "array", "items": { "$ref": "#/definitions/presetInfo" } },
        "chain":   { "$ref": "#/definitions/chain" },
        "noteMap": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 127 }, "minItems": 128, "maxItems": 128 }
      },
      "required": ["preset", "seed", "scene", "macros", "lanes", "presets"]
    },

    "frameLane": {
      "type": "object",
      "properties": {
        "ph":   { "type": "number", "minimum": 0, "maximum": 1 },
        "step": { "type": "integer", "minimum": 0 }
      },
      "required": ["ph", "step"]
    },

    "frame": {
      "type": "object",
      "properties": {
        "t8":       { "type": "number", "minimum": 0 },
        "playing":  { "type": "boolean" },
        "convLeft": { "type": "integer", "minimum": 0 },
        "lanes":    { "type": "array", "items": { "$ref": "#/definitions/frameLane" } }
      },
      "required": ["t8", "playing", "convLeft", "lanes"]
    },

    "msgReady": {
      "type": "object",
      "properties": {
        "type": { "const": "ready" },
        "v":    { "type": "integer" }
      },
      "required": ["type", "v"]
    },

    "msgEdit": {
      "type": "object",
      "properties": {
        "type":    { "const": "edit" },
        "v":       { "type": "integer" },
        "paramId": { "type": "string", "minLength": 1 },
        "value":   { "type": "number" },
        "gesture": { "type": "string", "enum": ["begin", "perform", "end"] }
      },
      "required": ["type", "v", "paramId", "value", "gesture"]
    },

    "msgAction": {
      "type": "object",
      "properties": {
        "type":    { "const": "action" },
        "v":       { "type": "integer" },
        "name":    { "type": "string", "enum": [
          "toggleStep", "setEuclid", "setCells", "setFixedStep", "setMicroTiming",
          "setEnvelope", "selectScene", "applyPreset", "togglePlay", "exportRequest",
          "chainAddEntry", "chainRemoveEntry", "resetNoteMap", "setNoteMap", "setAccent"
        ] },
        "payload": { "type": "object" }
      },
      "required": ["type", "v", "name", "payload"]
    },

    "msgState": {
      "type": "object",
      "properties": {
        "type":  { "const": "state" },
        "state": { "$ref": "#/definitions/state" }
      },
      "required": ["type", "state"]
    },

    "msgFrame": {
      "type": "object",
      "properties": {
        "type":  { "const": "frame" },
        "frame": { "$ref": "#/definitions/frame" }
      },
      "required": ["type", "frame"]
    },

    "payloadToggleStep": {
      "type": "object",
      "properties": {
        "lane": { "type": "integer", "minimum": 0, "maximum": 7 },
        "step": { "type": "integer", "minimum": 0, "maximum": 63 }
      },
      "required": ["lane", "step"],
      "additionalProperties": false
    },

    "payloadSetEuclid": {
      "type": "object",
      "properties": {
        "lane":     { "type": "integer", "minimum": 0, "maximum": 7 },
        "steps":    { "type": "integer", "minimum": 1, "maximum": 64 },
        "hits":     { "type": "integer", "minimum": 0 },
        "rotation": { "type": "integer" }
      },
      "required": ["lane"],
      "additionalProperties": false
    },

    "payloadSetCells": {
      "type": "object",
      "properties": {
        "lane":  { "type": "integer", "minimum": 0, "maximum": 7 },
        "cells": { "oneOf": [{ "type": "null" }, { "type": "array", "items": { "type": "integer", "minimum": 1 } }] }
      },
      "required": ["lane", "cells"],
      "additionalProperties": false
    },

    "payloadSetFixedStep": {
      "type": "object",
      "properties": {
        "lane": { "type": "integer", "minimum": 0, "maximum": 7 },
        "step": { "type": "integer", "minimum": 0, "maximum": 63 },
        "on":   { "type": "boolean" }
      },
      "required": ["lane", "step", "on"],
      "additionalProperties": false
    },

    "payloadSetMicroTiming": {
      "type": "object",
      "properties": {
        "lane": { "type": "integer", "minimum": 0, "maximum": 7 },
        "step": { "type": "integer", "minimum": 0, "maximum": 63 },
        "ms":   { "type": "number", "minimum": -20, "maximum": 20 }
      },
      "required": ["lane", "step", "ms"],
      "additionalProperties": false
    },

    "payloadSetEnvelope": {
      "type": "object",
      "properties": {
        "lane":     { "type": "integer", "minimum": 0, "maximum": 7 },
        "index":    { "type": "integer", "minimum": 0 },
        "envelope": { "oneOf": [
          { "type": "null" },
          { "$ref": "#/definitions/envelope" }
        ]}
      },
      "required": ["lane", "index"],
      "additionalProperties": false
    },

    "payloadSelectScene": {
      "type": "object",
      "properties": {
        "scene": { "type": "string", "enum": ["A", "B", "Morph"] }
      },
      "required": ["scene"],
      "additionalProperties": false
    },

    "payloadApplyPreset": {
      "description": "index=-1 loads Init (all lanes cleared). index>=0 selects a factory preset from the runtime inventory (site/src/generated/presets.json). No hard maximum here: bounds are enforced by the native side against the actual inventory.",
      "type": "object",
      "properties": {
        "index": {
          "type": "integer",
          "minimum": -1,
          "description": "-1 = Init; 0..N-1 = factory preset where N = presets.length from presets.json"
        }
      },
      "required": ["index"],
      "additionalProperties": false
    },

    "payloadChainRemoveEntry": {
      "type": "object",
      "properties": {
        "index": { "type": "integer", "minimum": 0 }
      },
      "required": ["index"],
      "additionalProperties": false
    },

    "payloadSetNoteMap": {
      "type": "object",
      "properties": {
        "note":   { "type": "integer", "minimum": 0, "maximum": 127 },
        "output": { "type": "integer", "minimum": 0, "maximum": 127 }
      },
      "required": ["note", "output"],
      "additionalProperties": false
    },

    "payloadSetAccent": {
      "type": "object",
      "properties": {
        "lane":  { "type": "integer", "minimum": 0, "maximum": 7 },
        "step":  { "type": "integer", "minimum": 0, "maximum": 63 },
        "value": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["lane", "step", "value"],
      "additionalProperties": false
    },

    "payloadEmpty": {
      "description": "Empty payload for: togglePlay, exportRequest, chainAddEntry, resetNoteMap",
      "type": "object",
      "additionalProperties": false
    }
  },

  "oneOf": [
    { "$ref": "#/definitions/msgReady" },
    { "$ref": "#/definitions/msgEdit" },
    { "$ref": "#/definitions/msgAction" },
    { "$ref": "#/definitions/msgState" },
    { "$ref": "#/definitions/msgFrame" }
  ]
}
